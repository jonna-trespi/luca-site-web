---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import BlogIndexPage from '../components/blog/BlogIndexPage.astro';
import { getAllPosts, getCategoryList } from '../lib/blog';

const posts = getAllPosts();
const categories = getCategoryList();
---

<Layout
  title="Blog - Luca"
  description="Ideas que transforman la educación. Artículos, recursos y contenido para el aula desde Luca: innovación pedagógica y herramientas para docentes e instituciones."
  canonicalPath="/blog/"
>
  <Header />
  <BlogIndexPage posts={posts} categories={categories} activeCategorySlug={null} />
  <Footer />
</Layout>
