---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Clientes from '../components/Clientes.astro';
import Impacto from '../components/Impacto.astro';
import Programas from '../components/Programas.astro';
import Comunidad from '../components/Comunidad.astro';
import Diferencia from '../components/Diferencia.astro';
import Casos from '../components/Casos.astro';
import BlogFaqs from '../components/BlogFaqs.astro';
import PrefooterCta from '../components/PrefooterCta.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Luca - Inicio"
  description="Descubre Luca: plataforma educativa con pedagogía, IA y contenidos para preescolar, primaria y secundaria. Transformamos el aprendizaje en las escuelas de México."
>
  <Header />
  <main>
    <Hero />
    <Clientes />
    <Impacto />
    <Programas />
    <Comunidad />
    <Diferencia />
    <Casos />
    <BlogFaqs />
    <PrefooterCta />
  </main>
  <Footer />
</Layout>
