---
/**
 * `/blog/{slug}/`: listado por categoría (slug = categoría) o redirección 301
 * desde la URL antigua del post (`/blog/{postSlug}/` → `/blog/{categoría}/{postSlug}/`).
 */
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogIndexPage from '../../components/blog/BlogIndexPage.astro';
import {
  getAllPosts,
  getPostBySlug,
  getCategoryList,
  getCategoryLabelFromSlug,
  getBlogPostPath,
  slugifyBlogCategory,
} from '../../lib/blog';

export function getStaticPaths() {
  const posts = getAllPosts();
  const postSlugSet = new Set(posts.map((p) => p.slug));
  const paths: { params: { slug: string } }[] = posts.map((post) => ({
    params: { slug: post.slug },
  }));
  for (const label of getCategoryList()) {
    const s = slugifyBlogCategory(label);
    if (!s || postSlugSet.has(s)) continue;
    paths.push({ params: { slug: s } });
  }
  return paths;
}

const slug = Astro.params.slug ?? '';
const post = getPostBySlug(slug);
if (post) {
  return Astro.redirect(getBlogPostPath(post), 301);
}

const categoryLabel = getCategoryLabelFromSlug(slug);
if (!categoryLabel) {
  return Astro.redirect('/blog/');
}

const posts = getAllPosts();
const categories = getCategoryList();
---

<Layout
  title={`${categoryLabel} - Blog Luca`}
  description={`Artículos del blog Luca en la categoría «${categoryLabel}».`}
  canonicalPath={`/blog/${slug}/`}
>
  <Header />
  <BlogIndexPage posts={posts} categories={categories} activeCategorySlug={slug} />
  <Footer />
</Layout>
