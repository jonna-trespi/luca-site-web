---
/**
 * Layout principal: metadatos SEO básicos (description, canonical, Open Graph, Twitter).
 */
import '../styles/global.css';
import { SITE_NAME, DEFAULT_DESCRIPTION, DEFAULT_OG_IMAGE_PATH } from '../config/seo';

interface Props {
  title?: string;
  description?: string;
  /** Ruta canónica (ej. /blog). Por defecto: pathname actual. */
  canonicalPath?: string;
  /** Ruta absoluta en el sitio para og:image (ej. /images/...). */
  image?: string;
  /** Ej. "noindex, nofollow" para páginas internas o borradores. */
  robots?: string;
}

const {
  title = SITE_NAME,
  description = DEFAULT_DESCRIPTION,
  canonicalPath,
  image = DEFAULT_OG_IMAGE_PATH,
  robots = 'index, follow',
} = Astro.props;

const canonicalURL = Astro.site
  ? new URL(canonicalPath ?? Astro.url.pathname, Astro.site)
  : null;
if (canonicalURL) {
  canonicalURL.search = '';
  canonicalURL.hash = '';
}

const ogImageUrl =
  image?.startsWith('http://') || image?.startsWith('https://')
    ? image
    : Astro.site && image
      ? new URL(image.startsWith('/') ? image : `/${image}`, Astro.site).href
      : null;
---

<!DOCTYPE html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="generator" content={Astro.generator} />
    {canonicalURL && <link rel="canonical" href={canonicalURL.href} />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="es_MX" />
    {canonicalURL && <meta property="og:url" content={canonicalURL.href} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="custom-cursor" id="custom-cursor" aria-hidden="true" hidden></div>
    <slot />
    <script is:inline>
      (function () {
        const el = document.getElementById('custom-cursor');
        if (!el) return;
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const touch = window.matchMedia('(hover: none), (pointer: coarse)').matches;
        if (reduced || touch) return;
        el.removeAttribute('hidden');
        document.documentElement.classList.add('custom-cursor--active');

        const interactive =
          'a[href], button, input, textarea, select, [role="button"], [tabindex]:not([tabindex="-1"]), label[for]';

        const onMove = function (e) {
          el.style.left = e.clientX + 'px';
          el.style.top = e.clientY + 'px';
        };

        const onOver = function (e) {
          const t = e.target;
          if (!(t instanceof Element)) return;
          /* Tarjetas staff: solo hover visual con tabindex; no son CTA — mantener la bolita (no “interactive” para el cursor) */
          if (t.closest('.somos-luca-equipo__card')) {
            el.classList.remove('custom-cursor--hover');
            return;
          }
          const hit = t.closest(interactive);
          el.classList.toggle('custom-cursor--hover', Boolean(hit));
        };

        document.addEventListener('mousemove', onMove, { passive: true });
        document.addEventListener('mouseover', onOver, { passive: true });

        /* iframes (p. ej. YouTube): el padre no recibe mousemove dentro del embed → la bolita queda
           congelada en el borde. Al entrar/salir ocultamos la bolita y el CSS devuelve cursor nativo. */
        const iframeHoverClass = 'custom-cursor--iframe-hover';
        const bindIframeCursor = function () {
          document.querySelectorAll('iframe').forEach(function (node) {
            if (!(node instanceof HTMLIFrameElement) || node.dataset.cursorIframeBound === '1') return;
            node.dataset.cursorIframeBound = '1';
            node.addEventListener(
              'mouseenter',
              function () {
                document.documentElement.classList.add(iframeHoverClass);
              },
              { passive: true }
            );
            node.addEventListener(
              'mouseleave',
              function () {
                document.documentElement.classList.remove(iframeHoverClass);
              },
              { passive: true }
            );
          });
        };
        bindIframeCursor();
        new MutationObserver(bindIframeCursor).observe(document.body, { childList: true, subtree: true });
      })();
    </script>
  </body>
</html>
