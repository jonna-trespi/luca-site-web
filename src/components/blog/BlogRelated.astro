---
import type { BlogPost } from '../../lib/blog';
import BlogCard from './BlogCard.astro';

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;
---

{
  posts.length > 0 ? (
    <section class="blog-related" aria-labelledby="blog-related-title">
      <div class="blog-related__inner layout-container">
        <h2 id="blog-related-title" class="blog-related__heading text-h4">
          Artículos relacionados<span class="blog-related__heading-dot">.</span>
        </h2>
        <ul class="blog-related__grid">
          {posts.map((post) => (
            <li class="blog-related__item">
              <BlogCard post={post} />
            </li>
          ))}
        </ul>
      </div>
    </section>
  ) : null
}

<style>
  .blog-related {
    width: 100%;
    background-color: #edf5ff;
    padding: clamp(2.5rem, 6vw, 4rem) 0;
    box-sizing: border-box;
  }

  .blog-related__inner.layout-container {
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--layout-padding-x);
    padding-right: var(--layout-padding-x);
  }

  @media (min-width: 1920px) {
    .blog-related__inner.layout-container {
      max-width: 1400px;
    }
  }

  .blog-related__heading {
    margin: 0 0 clamp(1.5rem, 4vw, 2.25rem);
    text-align: left;
    color: var(--color-text-base);
  }

  .blog-related__heading-dot {
    color: var(--color-red);
  }

  .blog-related__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 64px 24px;
  }

  @media (min-width: 768px) {
    .blog-related__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .blog-related__item {
    min-width: 0;
  }
</style>
