---
/**
 * Modal "Solicita demo": Web-to-Lead Salesforce + reCAPTCHA.
 */
---

<script src="https://www.google.com/recaptcha/api.js" async defer></script>

<div class="demo-modal" id="demo-modal" data-demo-modal hidden aria-hidden="true">
  <div class="demo-modal__backdrop" data-demo-modal-close tabindex="-1" aria-hidden="true"></div>
  <div
    class="demo-modal__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="demo-modal-title"
    aria-describedby="demo-modal-desc"
    tabindex="-1"
  >
    <button type="button" class="demo-modal__close" data-demo-modal-close aria-label="Cerrar">
      <span class="demo-modal__close-icon" aria-hidden="true"></span>
    </button>

    <div class="form-container">
      <div class="form-header">
        <h2 class="form-title" id="demo-modal-title">Deja de imaginarlo. Empieza a vivirlo.</h2>
        <p class="form-subtitle" id="demo-modal-desc">Selecciona los niveles que te interesan.</p>
      </div>

      <form
        class="luca-form"
        id="luca-demo-webtolead-form"
        action="https://webto.salesforce.com/servlet/servlet.WebToLead?encoding=UTF-8&orgId=00Dal000013TFyw"
        method="POST"
        target="_blank"
      >
        <input
          type="hidden"
          name="captcha_settings"
          value='{"keyname":"NEWKAP2","fallback":"true","orgId":"00Dal000013TFyw","ts":""}'
        />
        <input type="hidden" name="oid" value="00Dal000013TFyw" />
        <input type="hidden" name="retURL" value="https://info.lucaedu.co/pagina-de-agradecimiento-lucaedu" />

        <div class="form-row">
          <div class="form-group">
            <label for="luca-demo-first_name">Nombres <span>*</span></label>
            <input
              id="luca-demo-first_name"
              name="first_name"
              type="text"
              placeholder="Tu nombre"
              required
              minlength="2"
              autocomplete="given-name"
            />
          </div>
          <div class="form-group">
            <label for="luca-demo-last_name">Apellidos <span>*</span></label>
            <input
              id="luca-demo-last_name"
              name="last_name"
              type="text"
              placeholder="Tus apellidos"
              required
              minlength="2"
              autocomplete="family-name"
            />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="luca-demo-email">Email <span>*</span></label>
            <input
              id="luca-demo-email"
              name="email"
              type="email"
              placeholder="email@ejemplo.com"
              required
              pattern="^[^\s@]+@[^\s@]+\.[^\s@]+$"
              autocomplete="email"
            />
            <small class="help-text">Ej: usuario@dominio.com</small>
          </div>
          <div class="form-group">
            <label for="luca-demo-phone">Teléfono <span>*</span></label>
            <input
              id="luca-demo-phone"
              name="phone"
              type="tel"
              placeholder="Número"
              required
              pattern="^\d{7,15}$"
              inputmode="numeric"
              autocomplete="tel"
            />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="luca-demo-company">Institución <span>*</span></label>
            <input
              id="luca-demo-company"
              name="company"
              type="text"
              placeholder="Nombre"
              required
              minlength="2"
              autocomplete="organization"
            />
          </div>
          <div class="form-group">
            <label for="luca-demo-title">Cargo</label>
            <input id="luca-demo-title" name="title" type="text" placeholder="Tu cargo" autocomplete="organization-title" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group custom-multiselect">
            <span class="form-group-label" id="luca-demo-nivel-label">Nivel educativo</span>
            <button type="button" class="multi-header" id="luca-demo-multi-toggle" aria-expanded="false" aria-haspopup="listbox" aria-controls="demo-modal-multi-content">
              <span id="demo-modal-multi-label">Selecciona niveles...</span>
            </button>
            <div class="multi-options" id="demo-modal-multi-content" role="listbox" aria-multiselectable="true" hidden>
              <label class="option-item">
                <input type="checkbox" class="level-checkbox" value="Kinder" /> Kinder
              </label>
              <label class="option-item">
                <input type="checkbox" class="level-checkbox" value="Primaria" /> Primaria
              </label>
              <label class="option-item">
                <input type="checkbox" class="level-checkbox" value="Secundaria" /> Secundaria
              </label>
              <label class="option-item">
                <input type="checkbox" class="level-checkbox" value="Preparatoria" /> Preparatoria
              </label>
            </div>
            <select id="00NVs00000NhYXJ" name="00NVs00000NhYXJ" multiple="multiple" class="visually-hidden-select" aria-hidden="true" tabindex="-1">
              <option value="Kinder">Kinder</option>
              <option value="Primaria">Primaria</option>
              <option value="Secundaria">Secundaria</option>
              <option value="Preparatoria">Preparatoria</option>
            </select>
          </div>
          <div class="form-group">
            <label for="luca-demo-alumnos">Cant. Alumnos</label>
            <input id="luca-demo-alumnos" name="00NVs00000Nhiwc" type="number" placeholder="Cantidad" min="1" step="1" inputmode="numeric" />
          </div>
        </div>

        <div class="form-row form-row--interest">
          <div class="form-group">
            <label for="luca-demo-interes">Interés Principal</label>
            <input id="luca-demo-interes" name="00NVs00000NhrnZ" type="text" placeholder="¿En qué podemos ayudarte?" />
          </div>
          <div class="form-group recaptcha-wrapper">
            <div
              class="g-recaptcha"
              data-sitekey="6LeooTssAAAAAFQtKU81E09Gciz5jZDlgt9JS3cd"
              data-callback="recaptchaCallback"
            >
            </div>
          </div>
        </div>
      </form>

      <div class="form-footer">
        <input type="submit" id="submit-btn" form="luca-demo-webtolead-form" value="Enviar" />
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var root = document.getElementById('demo-modal');
    if (!root) return;

    function q(sel) {
      return root.querySelector(sel);
    }
    function qa(sel) {
      return root.querySelectorAll(sel);
    }

    function timestamp() {
      var response = document.getElementById('g-recaptcha-response');
      if (response == null || response.value.trim() == '') {
        var cap = qa('input[name="captcha_settings"]')[0];
        if (!cap) return;
        var elems = JSON.parse(cap.value);
        elems['ts'] = JSON.stringify(new Date().getTime());
        cap.value = JSON.stringify(elems);
      }
    }
    setInterval(timestamp, 500);

    function toggleMultiselect() {
      var content = document.getElementById('demo-modal-multi-content');
      var btn = document.getElementById('luca-demo-multi-toggle');
      if (!content) return;
      var open = content.hasAttribute('hidden');
      if (open) {
        content.removeAttribute('hidden');
        if (btn) btn.setAttribute('aria-expanded', 'true');
      } else {
        content.setAttribute('hidden', '');
        if (btn) btn.setAttribute('aria-expanded', 'false');
      }
    }

    function updateSalesforceField() {
      var checkboxes = qa('.level-checkbox');
      var realSelect = document.getElementById('00NVs00000NhYXJ');
      var displayLabel = document.getElementById('demo-modal-multi-label');
      if (!realSelect || !displayLabel) return;
      var selectedValues = [];
      checkboxes.forEach(function (cb) {
        var option = Array.from(realSelect.options).find(function (opt) {
          return opt.value === cb.value;
        });
        if (option) {
          if (cb.checked) {
            option.selected = true;
            selectedValues.push(cb.value);
          } else {
            option.selected = false;
          }
        }
      });
      if (selectedValues.length > 0) {
        displayLabel.innerText = selectedValues.join(', ');
        displayLabel.style.color = '#333';
      } else {
        displayLabel.innerText = 'Selecciona niveles...';
        displayLabel.style.color = '#999';
      }
    }

    document.addEventListener('click', function (event) {
      var content = document.getElementById('demo-modal-multi-content');
      if (!content || root.hidden) return;
      if (event.target.closest('.custom-multiselect')) return;
      content.setAttribute('hidden', '');
      var btn = document.getElementById('luca-demo-multi-toggle');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    });

    function validateFieldVisual(input) {
      if (!input) return true;
      var value = input.value.trim();
      var isRequired = input.hasAttribute('required');
      if (!value) {
        input.classList.remove('valid', 'invalid');
        return !isRequired;
      }
      var isValid = true;
      if (input.type === 'email') {
        isValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
      } else if (input.name === 'phone') {
        isValid = /^\d{7,15}$/.test(value);
      } else if (input.hasAttribute('minlength')) {
        isValid = value.length >= parseInt(input.getAttribute('minlength'), 10);
      }
      if (isValid) {
        input.classList.remove('invalid');
        input.classList.add('valid');
      } else {
        input.classList.remove('valid');
        input.classList.add('invalid');
      }
      return isValid;
    }

    function validateForm() {
      var firstNameInput = q('input[name="first_name"]');
      var lastNameInput = q('input[name="last_name"]');
      var emailInput = q('input[name="email"]');
      var phoneInput = q('input[name="phone"]');
      var companyInput = q('input[name="company"]');
      var recaptchaResponse = document.getElementById('g-recaptcha-response');
      var submitBtn = document.getElementById('submit-btn');
      if (!submitBtn) return;

      var firstNameValid = validateFieldVisual(firstNameInput);
      var lastNameValid = validateFieldVisual(lastNameInput);
      var emailValid = validateFieldVisual(emailInput);
      var phoneValid = validateFieldVisual(phoneInput);
      var companyValid = validateFieldVisual(companyInput);
      var recaptchaValid = recaptchaResponse && recaptchaResponse.value.trim() !== '';

      if (firstNameValid && lastNameValid && emailValid && phoneValid && companyValid && recaptchaValid) {
        submitBtn.disabled = false;
        submitBtn.classList.remove('disabled');
      } else {
        submitBtn.disabled = true;
        submitBtn.classList.add('disabled');
      }
    }

    function preventNonNumeric(e) {
      if (
        [46, 8, 9, 27, 13].indexOf(e.keyCode) !== -1 ||
        (e.keyCode === 65 && e.ctrlKey === true) ||
        (e.keyCode === 67 && e.ctrlKey === true) ||
        (e.keyCode === 86 && e.ctrlKey === true) ||
        (e.keyCode === 88 && e.ctrlKey === true) ||
        (e.keyCode === 65 && e.metaKey === true) ||
        (e.keyCode === 67 && e.metaKey === true) ||
        (e.keyCode === 86 && e.metaKey === true) ||
        (e.keyCode === 88 && e.metaKey === true) ||
        (e.keyCode >= 35 && e.keyCode <= 39)
      ) {
        return;
      }
      if ((e.shiftKey || e.keyCode < 48 || e.keyCode > 57) && (e.keyCode < 96 || e.keyCode > 105)) {
        e.preventDefault();
      }
    }

    function filterNumericInput(input) {
      var value = input.value;
      var numericValue = value.replace(/[^0-9]/g, '');
      if (value !== numericValue) {
        input.value = numericValue;
      }
    }

    window.recaptchaCallback = function () {
      validateForm();
    };

    function initFormBindings() {
      var submitBtn = document.getElementById('submit-btn');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.classList.add('disabled');
      }

      var phoneInput = q('input[name="phone"]');
      var alumnosInput = q('input[name="00NVs00000Nhiwc"]');

      if (phoneInput) {
        phoneInput.addEventListener('keydown', preventNonNumeric);
        phoneInput.addEventListener('input', function () {
          filterNumericInput(phoneInput);
          validateForm();
        });
        phoneInput.addEventListener('paste', function () {
          setTimeout(function () {
            filterNumericInput(phoneInput);
            validateForm();
          }, 10);
        });
      }

      if (alumnosInput) {
        alumnosInput.addEventListener('keydown', preventNonNumeric);
        alumnosInput.addEventListener('input', function () {
          filterNumericInput(alumnosInput);
        });
        alumnosInput.addEventListener('paste', function () {
          setTimeout(function () {
            filterNumericInput(alumnosInput);
          }, 10);
        });
      }

      var requiredFields = [
        'input[name="first_name"]',
        'input[name="last_name"]',
        'input[name="email"]',
        'input[name="phone"]',
        'input[name="company"]',
      ];
      requiredFields.forEach(function (selector) {
        var field = q(selector);
        if (field) {
          field.addEventListener('input', validateForm);
          field.addEventListener('blur', validateForm);
        }
      });

      qa('.level-checkbox').forEach(function (cb) {
        cb.addEventListener('change', function () {
          updateSalesforceField();
          validateForm();
        });
      });

      var toggleBtn = document.getElementById('luca-demo-multi-toggle');
      if (toggleBtn) {
        toggleBtn.addEventListener('click', function (e) {
          e.stopPropagation();
          toggleMultiselect();
        });
      }

      setInterval(validateForm, 500);

      var formEl = q('.luca-form');
      if (formEl) {
        formEl.addEventListener('submit', function (e) {
          var btn = document.getElementById('submit-btn');
          if (btn && btn.disabled) {
            e.preventDefault();
            var missingFields = [];
            if (!q('input[name="first_name"]').value.trim()) missingFields.push('Nombres');
            if (!q('input[name="last_name"]').value.trim()) missingFields.push('Apellidos');
            var email = q('input[name="email"]').value.trim();
            if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
              missingFields.push('Email válido (ejemplo@mail.com)');
            }
            var phone = q('input[name="phone"]').value.trim();
            if (!phone || !/^\d{7,15}$/.test(phone)) {
              missingFields.push('Teléfono válido (mínimo 7 números)');
            }
            if (!q('input[name="company"]').value.trim()) missingFields.push('Institución');
            var recaptcha = document.getElementById('g-recaptcha-response');
            if (!recaptcha || !recaptcha.value.trim()) {
              missingFields.push('Verificación reCAPTCHA');
            }
            alert('Por favor completa los siguientes campos:\n\n• ' + missingFields.join('\n• '));
            return false;
          }
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFormBindings);
    } else {
      initFormBindings();
    }
  })();
</script>

<script>
  (function () {
    const root = document.getElementById('demo-modal');
    const panel = root?.querySelector<HTMLElement>('.demo-modal__panel');
    if (!root || !panel) return;

    let lastFocus: HTMLElement | null = null;

    const open = () => {
      lastFocus = document.activeElement as HTMLElement;
      root.hidden = false;
      root.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      const firstFocus =
        panel.querySelector<HTMLElement>('#luca-demo-multi-toggle, input, select, textarea, button') ||
        panel;
      firstFocus.focus();
    };

    const close = () => {
      root.hidden = true;
      root.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      lastFocus?.focus?.();
      lastFocus = null;
    };

    document.querySelectorAll('[data-open-demo-modal]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        open();
      });
    });

    root.querySelectorAll('[data-demo-modal-close]').forEach((el) => {
      el.addEventListener('click', () => close());
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !root.hidden) close();
    });
  })();
</script>

<style>
  .demo-modal {
    position: fixed;
    inset: 0;
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--layout-padding-x);
    box-sizing: border-box;
  }

  .demo-modal[hidden] {
    display: none !important;
  }

  .demo-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(51, 51, 51, 0.45);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .demo-modal__panel {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 760px;
    max-height: min(92vh, 900px);
    overflow-y: auto;
    margin: auto;
    padding: 1.5rem 1.25rem 1.25rem;
    background: var(--color-white);
    border-radius: 24px;
    box-shadow: 0 16px 48px rgba(40, 48, 148, 0.18);
    outline: none;
  }

  .demo-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 12px;
    background: rgba(56, 67, 208, 0.08);
    color: var(--color-blue-primary);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    z-index: 2;
  }

  .demo-modal__close:hover {
    background: rgba(56, 67, 208, 0.15);
    color: var(--color-blue-secondary);
  }

  .demo-modal__close-icon {
    width: 18px;
    height: 18px;
    position: relative;
  }

  .demo-modal__close-icon::before,
  .demo-modal__close-icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
  }

  .demo-modal__close-icon::before {
    transform: translateY(-50%) rotate(45deg);
  }

  .demo-modal__close-icon::after {
    transform: translateY(-50%) rotate(-45deg);
  }

  /* ===== Formulario Web-to-Lead (scoped) ===== */
  .demo-modal .form-container {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    padding: 0 0 4px;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  .demo-modal .form-header {
    background: white;
    padding: 0 10px 16px 10px;
    padding-right: 2.75rem;
  }

  .demo-modal .form-title {
    font-family: var(--font-family-base);
    font-weight: 500;
    font-size: 20px;
    color: #3d3d3d;
    margin: 0;
    line-height: 1.2;
  }

  .demo-modal .form-subtitle {
    font-family: var(--font-family-base);
    font-weight: 400;
    font-size: 16px;
    color: #3d3d3d;
    margin: 0.5rem 0 0;
    line-height: 1.2;
  }

  .demo-modal .luca-form {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 0 10px;
  }

  .demo-modal .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .demo-modal .form-row--interest {
    align-items: end;
  }

  .demo-modal .form-group {
    display: flex;
    flex-direction: column;
  }

  .demo-modal .form-group.full-width {
    grid-column: 1 / -1;
  }

  .demo-modal .form-group-label {
    font-family: var(--font-family-base);
    font-weight: 400;
    font-size: 14px;
    color: #3d3d3d;
    margin-bottom: 4px;
    display: block;
  }

  .demo-modal .luca-form label {
    font-family: var(--font-family-base);
    font-weight: 400;
    font-size: 14px;
    color: #3d3d3d;
    margin-bottom: 4px;
    display: block;
  }

  .demo-modal .luca-form input[type='text'],
  .demo-modal .luca-form input[type='email'],
  .demo-modal .luca-form input[type='tel'],
  .demo-modal .luca-form input[type='number'],
  .demo-modal .luca-form select,
  .demo-modal .multi-header {
    font-family: var(--font-family-base);
    font-weight: 400;
    font-size: 14px;
    padding: 10px 16px;
    border: 1px solid #c3c3c3;
    border-radius: 8px;
    transition: all 0.3s ease;
    color: #3d3d3d;
    background: white;
    box-sizing: border-box;
    width: 100%;
  }

  .demo-modal .multi-header {
    text-align: left;
    cursor: pointer;
  }

  .demo-modal .luca-form input[type='text']::placeholder,
  .demo-modal .luca-form input[type='email']::placeholder,
  .demo-modal .luca-form input[type='tel']::placeholder,
  .demo-modal .luca-form input[type='number']::placeholder {
    font-family: var(--font-family-base);
    font-weight: 400;
    font-size: 14px;
    color: #c3c3c3;
  }

  .demo-modal .luca-form input[type='text']:focus,
  .demo-modal .luca-form input[type='email']:focus,
  .demo-modal .luca-form input[type='tel']:focus,
  .demo-modal .luca-form input[type='number']:focus,
  .demo-modal .luca-form select:focus,
  .demo-modal .multi-header:focus {
    outline: none;
    border-color: #3843d0;
    box-shadow: 0 0 0 3px rgba(56, 67, 208, 0.1);
  }

  .demo-modal .luca-form input[type='number']::-webkit-inner-spin-button,
  .demo-modal .luca-form input[type='number']::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .demo-modal .luca-form input[type='number'] {
    -moz-appearance: textfield;
  }

  .demo-modal .custom-multiselect {
    position: relative;
    cursor: pointer;
  }

  .demo-modal .multi-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: #c3c3c3;
  }

  .demo-modal .multi-header::after {
    content: '';
    border: solid #c3c3c3;
    border-width: 0 2px 2px 0;
    display: inline-block;
    padding: 3px;
    transform: rotate(45deg);
  }

  .demo-modal .multi-options {
    position: absolute;
    top: calc(100% + 5px);
    left: 0;
    width: 100%;
    background: white;
    border: 1px solid #c3c3c3;
    border-radius: 8px;
    z-index: 100;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    padding: 5px 0;
    max-height: 200px;
    overflow-y: auto;
  }

  .demo-modal .multi-options[hidden] {
    display: none !important;
  }

  .demo-modal .option-item {
    padding: 10px 16px;
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 16px;
    font-family: var(--font-family-base);
    cursor: pointer;
  }

  .demo-modal .visually-hidden-select {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .demo-modal input[name='00NVs00000NhrnZ'] {
    width: 115%;
    max-width: none;
  }

  .demo-modal .recaptcha-wrapper {
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
  }

  .demo-modal .recaptcha-wrapper .g-recaptcha {
    transform: scale(0.8);
    transform-origin: bottom right;
  }

