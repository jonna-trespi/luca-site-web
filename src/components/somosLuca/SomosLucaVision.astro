---
/**
 * Somos Luca — Nuestra visión: abanico 2D + volteo en eje Y (rotateY).
 */
---

<section class="somos-luca-vision" aria-labelledby="somos-luca-vision-heading">
  <div class="somos-luca-vision__inner layout-container">
    <header class="somos-luca-vision__header">
      <p class="programas__label">
        <span class="programas__label-dot" aria-hidden="true"></span>
        Nuestra visión
      </p>
      <h2 id="somos-luca-vision-heading" class="text-h4 somos-luca-vision__title">
        Combinamos lo mejor de la pedagogía internacional con tecnología de vanguardia.
      </h2>
    </header>

    <div class="somos-luca-vision__perspective" data-somos-luca-vision-deck>
      <div class="somos-luca-vision__deck">
        <article
          class="somos-luca-vision__card somos-luca-vision__card--left"
          aria-labelledby="somos-luca-card-left-title"
          tabindex="0"
        >
          <div class="somos-luca-vision__flip">
            <div class="somos-luca-vision__flip-inner">
              <div class="somos-luca-vision__flip-face somos-luca-vision__flip-face--front">
                <h3 id="somos-luca-card-left-title" class="text-h4 somos-luca-vision__card-title">
                  Innovación educativa
                </h3>
                <p class="somos-luca-vision__card-body text-body-primary">
                  Con contenidos digitales de alta calidad adaptados a las necesidades de cada estudiante.
                </p>
              </div>
              <div class="somos-luca-vision__flip-face somos-luca-vision__flip-face--back" aria-hidden="true"></div>
            </div>
          </div>
        </article>
        <article
          class="somos-luca-vision__card somos-luca-vision__card--center"
          aria-labelledby="somos-luca-card-center-title"
          tabindex="0"
        >
          <div class="somos-luca-vision__flip">
            <div class="somos-luca-vision__flip-inner">
              <div class="somos-luca-vision__flip-face somos-luca-vision__flip-face--front">
                <h3 id="somos-luca-card-center-title" class="text-h4 somos-luca-vision__card-title">
                  Aprendizaje híbrido
                </h3>
                <p class="somos-luca-vision__card-body text-body-primary">
                  Combinamos lo mejor del aprendizaje digital y físico para mejor comprensión de los contenidos.
                </p>
              </div>
              <div class="somos-luca-vision__flip-face somos-luca-vision__flip-face--back" aria-hidden="true"></div>
            </div>
          </div>
        </article>
        <article
          class="somos-luca-vision__card somos-luca-vision__card--right"
          aria-labelledby="somos-luca-card-right-title"
          tabindex="0"
        >
          <div class="somos-luca-vision__flip">
            <div class="somos-luca-vision__flip-inner">
              <div class="somos-luca-vision__flip-face somos-luca-vision__flip-face--front">
                <h3 id="somos-luca-card-right-title" class="text-h4 somos-luca-vision__card-title">
                  México como el corazón de nuestra misión
                </h3>
                <p class="somos-luca-vision__card-body text-body-primary">
                  Apoyamos a las escuelas y <strong>los docentes</strong> con herramientas que resuenan con la realidad local.
                </p>
              </div>
              <div class="somos-luca-vision__flip-face somos-luca-vision__flip-face--back" aria-hidden="true"></div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  .somos-luca-vision {
    width: 100%;
    padding: clamp(3rem, 6vw, 5rem) 0 clamp(3.5rem, 7vw, 6rem);
    padding-bottom: 0;
    background: var(--color-white);
    box-sizing: border-box;
  }

  .somos-luca-vision__header {
    text-align: center;
    margin-bottom: 16px;
  }

  .somos-luca-vision__title {
    margin: 0 auto;
    max-width: 650px;
    color: #1d1d1d;
  }

  .somos-luca-vision__perspective {
    padding: clamp(1rem, 2vw, 1.5rem) 0 clamp(2rem, 4vw, 3rem);
    overflow: visible;
  }

  .somos-luca-vision__deck {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: flex-end;
    max-width: 960px;
    margin: 0 auto;
    min-height: min(400px, 56vw);
    padding-bottom: 0.5rem;
  }

  .somos-luca-vision__card {
    position: relative;
    flex: 0 0 auto;
    width: min(280px, 29vw);
    min-width: 220px;
    padding: 0;
    background: transparent;
    box-shadow: none;
    outline: none;
    transform-style: preserve-3d;
    transition: z-index 0s linear 0s;
    cursor: pointer;
  }

  .somos-luca-vision__card:focus-visible {
    border-radius: 30px;
    box-shadow: 0 0 0 3px rgba(56, 67, 208, 0.45);
  }

  .somos-luca-vision__flip {
    perspective: 920px;
    perspective-origin: 50% 50%;
    width: 100%;
    min-height: 320px;
  }

  /* Volteo únicamente en eje Y (sin rotateX / rotateZ en el inner) */
  .somos-luca-vision__flip-inner {
    position: relative;
    width: 100%;
    min-height: 320px;
    transform-style: preserve-3d;
    transition: transform 1.15s cubic-bezier(0.33, 0.86, 0.32, 1);
    transform: rotateY(180deg);
    transform-origin: 50% 50%;
  }

  .somos-luca-vision__card:hover .somos-luca-vision__flip-inner,
  .somos-luca-vision__card:focus-within .somos-luca-vision__flip-inner {
    transform: rotateY(0deg);
  }

  .somos-luca-vision__flip-face {
    position: absolute;
    inset: 0;
    border-radius: 28px;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.16);
    box-sizing: border-box;
    color: var(--color-white);
  }

  .somos-luca-vision__flip-face--front {
    transform: rotateY(0deg);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5rem;
    text-align: left;
  }

  /* Boca abajo (reverso): ilustración; visible en reposo */
  .somos-luca-vision__flip-face--back {
    transform: rotateY(180deg);
    padding: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .somos-luca-vision__card--left .somos-luca-vision__flip-face--front {
    background-color: #e8a92d;
  }

  .somos-luca-vision__card--left .somos-luca-vision__flip-face--back {
    background-color: #e8a92d;
    background-image: url('/images/somosLuca/card-yellow.webp');
  }

  .somos-luca-vision__card--center .somos-luca-vision__flip-face--front {
    background-color: #3868d0;
  }

  .somos-luca-vision__card--center .somos-luca-vision__flip-face--back {
    background-color: #3868d0;
    background-image: url('/images/somosLuca/card-blue.webp');
  }

  .somos-luca-vision__card--right .somos-luca-vision__flip-face--front {
    background-color: #248e86;
  }

  .somos-luca-vision__card--right .somos-luca-vision__flip-face--back {
    background-color: #248e86;
    background-image: url('/images/somosLuca/card-green.webp');
  }

  .somos-luca-vision__card-title {
    margin: 0;
    color: inherit;
    font-size: clamp(1.1rem, 2.2vw, 1.35rem);
    line-height: 1.25;
  }

  .somos-luca-vision__card-body {
    margin: 0;
    color: inherit;
    font-size: clamp(0.9375rem, 1.6vw, 1.0625rem);
    line-height: 1.45;
    opacity: 0.98;
  }

  .somos-luca-vision__card-body strong {
    font-weight: var(--text-body-primary-highlight-weight);
  }

  /* Abanico + capas (reposo) */
  .somos-luca-vision__card--left {
    z-index: 1;
    transform-origin: 50% 100%;
    margin-right: clamp(-4.75rem, -12vw, -3.25rem);
    transform: rotate(-10deg);
  }

  .somos-luca-vision__card--center {
    z-index: 2;
    transform-origin: 50% 100%;
    margin-left: clamp(-5.25rem, -13vw, -3.75rem);
    margin-right: clamp(-5.25rem, -13vw, -3.75rem);
    transform: rotate(0deg);
  }

  .somos-luca-vision__card--right {
    z-index: 3;
    transform-origin: 50% 100%;
    margin-left: clamp(-4.75rem, -12vw, -3.25rem);
    transform: rotate(10deg);
  }

  .somos-luca-vision__card:hover,
  .somos-luca-vision__card:focus-within {
    z-index: 25;
    transition: z-index 0s linear 0s;
  }

  .somos-luca-vision__card:hover .somos-luca-vision__flip-face,
  .somos-luca-vision__card:focus-within .somos-luca-vision__flip-face {
    box-shadow: 0 24px 52px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 900px) {
    .somos-luca-vision__deck {
      min-height: 0;
    }

    .somos-luca-vision__card {
      width: min(260px, 42vw);
      min-width: 200px;
    }

    .somos-luca-vision__flip,
    .somos-luca-vision__flip-inner {
      min-height: 300px;
    }

    .somos-luca-vision__card--left {
      margin-right: clamp(-4rem, -11vw, -2.75rem);
    }

    .somos-luca-vision__card--center {
      margin-left: clamp(-4.25rem, -12vw, -3rem);
      margin-right: clamp(-4.25rem, -12vw, -3rem);
    }

    .somos-luca-vision__card--right {
      margin-left: clamp(-4rem, -11vw, -2.75rem);
    }
  }

  @media (max-width: 767px) {
    .somos-luca-vision__perspective {
      padding-bottom: 1rem;
    }

    .somos-luca-vision__deck {
      flex-direction: column;
      gap: 1.25rem;
      align-items: center;
    }

    .somos-luca-vision__card {
      width: min(100%, 340px);
      min-width: unset;
      margin: 0 !important;
      transform: none !important;
    }

    .somos-luca-vision__card--center {
      order: -1;
      z-index: 2 !important;
    }

    .somos-luca-vision__card--left {
      z-index: 1 !important;
    }

    .somos-luca-vision__card--right {
      z-index: 3 !important;
    }

    /* Altura al contenido; título y cuerpo con ~64px entre ellos (sin space-between) */
    .somos-luca-vision__flip {
      min-height: 0;
    }

    .somos-luca-vision__flip-inner {
      min-height: 0;
    }

    .somos-luca-vision__flip-face {
      position: relative;
      inset: auto;
      width: 100%;
    }

    .somos-luca-vision__flip-face--back {
      display: none;
    }

    .somos-luca-vision__flip-face--front {
      justify-content: flex-start;
      gap: 64px;
    }

    .somos-luca-vision__card:hover,
    .somos-luca-vision__card:focus-within {
      z-index: 8 !important;
    }

    /* Texto visible, sin volteo ni transición */
    .somos-luca-vision__flip-inner {
      transform: rotateY(0deg) !important;
      transition: none !important;
    }

    .somos-luca-vision__card:hover .somos-luca-vision__flip-inner,
    .somos-luca-vision__card:focus-within .somos-luca-vision__flip-inner {
      transform: rotateY(0deg) !important;
    }

    .somos-luca-vision__card:hover .somos-luca-vision__flip-face,
    .somos-luca-vision__card:focus-within .somos-luca-vision__flip-face {
      box-shadow: 0 18px 42px rgba(0, 0, 0, 0.16);
    }

    .somos-luca-vision__card {
      cursor: default;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .somos-luca-vision__flip-inner {
      transform: rotateY(0deg) !important;
      transition: none;
    }

    .somos-luca-vision__card {
      transition: none;
    }

    .somos-luca-vision__card--left,
    .somos-luca-vision__card--center,
    .somos-luca-vision__card--right {
      transform: none !important;
      margin-left: 0 !important;
      margin-right: 0 !important;
    }

    .somos-luca-vision__deck {
      flex-direction: column;
      gap: 1rem;
      align-items: center;
    }
  }
</style>
