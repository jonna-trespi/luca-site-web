---
/**
 * Directores: titular + vídeo local (sin controles, sin sonido) y geo decorativas.
 * Assets: public/images/perfiles/directores/geo-*.png, public/videos/perfiles/directores/video-hero.mp4
 */
const baseImg = '/images/perfiles/directores';
const videoSrc = '/videos/perfiles/directores/video-hero.mp4';
---

<section
  id="perfil-directores-video-zoom"
  class="perfil-directores-video-zoom"
  aria-labelledby="perfil-directores-video-zoom-title"
>
  <div class="perfil-directores-video-zoom__geo-right" aria-hidden="true">
    <img
      class="perfil-directores-video-zoom__geo-right-img"
      src={`${baseImg}/geo-1.webp`}
      alt=""
      width="320"
      height="400"
      loading="lazy"
      decoding="async"
    />
  </div>

  <div class="perfil-directores-video-zoom__inner layout-container">
    <h3 id="perfil-directores-video-zoom-title" class="text-h3 perfil-directores-video-zoom__title">
      44% del tiempo de un director se destina a tareas administrativas,<br
        class="perfil-directores-video-zoom__title-br"
      />
      limitando el liderazgo pedagógico.
    </h3>

    <div class="perfil-directores-video-zoom__media">
      <div class="perfil-directores-video-zoom__geo-bl" aria-hidden="true">
        <img
          src={`${baseImg}/geo-2.webp`}
          alt=""
          width="200"
          height="200"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="perfil-directores-video-zoom__shell">
        <video
          class="perfil-directores-video-zoom__video"
          muted
          playsinline
          autoplay
          loop
          preload="metadata"
          aria-label="Video sobre directores escolares"
        >
          <source src={videoSrc} type="video/mp4" />
        </video>
      </div>
    </div>
  </div>
</section>

<style>
  .perfil-directores-video-zoom {
    position: relative;
    width: 100%;
    background-color: var(--color-bg-base);
    padding: 3rem 0;
    overflow: hidden;
    z-index: 0;
    box-sizing: border-box;
  }

  .perfil-directores-video-zoom__inner {
    position: relative;
    z-index: 1;
  }

  .perfil-directores-video-zoom__geo-right {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-32%);
    z-index: 0;
    width: 100%;
    max-width: 320px;
    pointer-events: none;
    user-select: none;
  }

  .perfil-directores-video-zoom__geo-right-img {
    display: block;
    width: 100%;
    max-width: 320px;
    height: auto;
    margin-left: auto;
    object-fit: contain;
    object-position: right center;
  }

  .perfil-directores-video-zoom__title {
    margin: 0 auto 90px;
    max-width: 56rem;
    text-align: center;
    color: var(--color-blue-secondary);
  }

  .perfil-directores-video-zoom__title-strong {
    font-weight: var(--text-body-primary-highlight-weight);
  }

  .perfil-directores-video-zoom__media {
    position: relative;
    width: 100%;
    max-width: min(960px, 100%);
    margin-left: auto;
    margin-right: auto;
  }

  .perfil-directores-video-zoom__geo-bl {
    position: absolute;
    left: clamp(-0.75rem, -2.5vw, -0.25rem);
    bottom: clamp(-1rem, -2.5vw, -0.5rem);
    z-index: 0;
    max-width: 200px;
    width: min(32%, 200px);
    pointer-events: none;
    user-select: none;
  }

  .perfil-directores-video-zoom__geo-bl img {
    width: 100%;
    max-width: 200px;
    height: auto;
    display: block;
  }

  .perfil-directores-video-zoom__shell {
    position: relative;
    z-index: 1;
    border-radius: 28px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--color-black);
    box-shadow:
      0 16px 48px rgba(40, 48, 148, 0.14),
      0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .perfil-directores-video-zoom__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (min-width: 1101px) {
    .perfil-directores-video-zoom {
      padding: 4rem 0;
    }
  }

  @media (min-width: 1101px) {
    .perfil-directores-video-zoom {
      padding: 5rem 0;
    }
  }

  @media (max-width: 1100px) {
    .perfil-directores-video-zoom__geo-right {
      opacity: 0.9;
      max-width: min(320px, 42vw);
    }

    .perfil-directores-video-zoom__geo-bl {
      width: min(40%, 200px);
    }
  }
</style>
