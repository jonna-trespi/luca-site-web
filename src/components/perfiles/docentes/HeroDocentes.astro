---
/**
 * Hero Docentes: franja 80%, fondo #3868D0, dos columnas (copy + imagen), CTA demo + plataforma (menú 3 niveles).
 * Imagen: public/images/perfiles/docentes/image-hero.webp
 */
const heroImageSrc = '/images/perfiles/docentes/image-hero.webp';
---

<section class="perfil-docentes-hero">
  <div class="perfil-docentes-hero__strip">
    <div class="perfil-docentes-hero__inner layout-container">
      <div class="perfil-docentes-hero__row">
        <header class="perfil-docentes-hero__content">
          <p class="programas__label programas__label--align-start">
            <span class="programas__label-dot" aria-hidden="true"></span>
            Docentes
          </p>
          <h1 id="perfil-docentes-hero-title" class="perfil-docentes-hero__title text-h1">
            Educación con sentido, apoyada por IA con Luca<span class="perfil-docentes-hero__title-dot" aria-hidden="true">.</span>
          </h1>
          <p class="perfil-docentes-hero__subtitle text-subtitle-1">
            Herramientas digitales para docentes
          </p>
          <div class="perfil-docentes-hero__ctas">
            <a href="/contacto" class="btn-base btn-primary btn-cta-animated" data-open-demo-modal>
              <span>Solicita tu demo</span>
              <span class="perfil-docentes-hero__btn-icon" aria-hidden="true"></span>
            </a>
            <div class="perfil-docentes-hero__plataforma-wrap" data-perfil-hero-plataforma-wrap>
              <button
                type="button"
                class="btn-base btn-secondary btn-cta-animated perfil-docentes-hero__plataforma-btn"
                data-perfil-hero-plataforma-btn
                aria-expanded="false"
                aria-haspopup="true"
                aria-controls="perfil-docentes-plataforma-panel"
                id="perfil-docentes-plataforma-btn"
              >
                <span>Ingresa a la plataforma</span>
                <span class="perfil-docentes-hero__btn-icon perfil-docentes-hero__btn-icon--person" aria-hidden="true"></span>
              </button>
              <div
                class="perfil-docentes-hero__mega"
                id="perfil-docentes-plataforma-panel"
                role="region"
                aria-labelledby="perfil-docentes-plataforma-btn"
              >
                <ul class="perfil-docentes-hero__mega-list">
                  <!-- <li>
                    <a
                      class="perfil-docentes-hero__mega-link"
                      href=""
                      target="_blank"
                      rel="noopener noreferrer">Preescolar</a>
                  </li> -->
                  <li>
                    <a
                      class="perfil-docentes-hero__mega-link"
                      href="https://app.lucaedu.com/"
                      target="_blank"
                      rel="noopener noreferrer">Primaria</a>
                  </li>
                  <li>
                    <a
                      class="perfil-docentes-hero__mega-link"
                      href="https://hs.app.lucaedu.com/"
                      target="_blank"
                      rel="noopener noreferrer">Secundaria</a>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </header>
        <div class="perfil-docentes-hero__media">
          <img
            class="perfil-docentes-hero__image"
            src={heroImageSrc}
            alt="Docente usando Luca en el aula"
            width="500"
            height="560"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    function closeAllPerfilHeroPlataforma() {
      document.querySelectorAll('[data-perfil-hero-plataforma-wrap]').forEach(function (w) {
        w.classList.remove('is-open');
        var b = w.querySelector('[data-perfil-hero-plataforma-btn]');
        if (b) b.setAttribute('aria-expanded', 'false');
      });
    }

    function initPerfilHeroPlataforma() {
      document.querySelectorAll('[data-perfil-hero-plataforma-wrap]').forEach(function (wrap) {
        if (wrap.dataset.perfilHeroPlataformaBound === 'true') return;
        wrap.dataset.perfilHeroPlataformaBound = 'true';
        var btn = wrap.querySelector('[data-perfil-hero-plataforma-btn]');
        if (!(btn instanceof HTMLButtonElement)) return;

        var isMobile = function () {
          return window.matchMedia('(max-width: 1100px)').matches;
        };

        btn.addEventListener('click', function (e) {
          e.stopPropagation();
          if (!isMobile()) return;
          var willOpen = !wrap.classList.contains('is-open');
          closeAllPerfilHeroPlataforma();
          if (willOpen) {
            wrap.classList.add('is-open');
            btn.setAttribute('aria-expanded', 'true');
          }
        });
      });

      if (!window.__lucaPerfilHeroPlataformaDoc) {
        window.__lucaPerfilHeroPlataformaDoc = true;
        document.addEventListener('click', function (e) {
          var t = e.target;
          if (!(t instanceof Node)) return;
          document.querySelectorAll('[data-perfil-hero-plataforma-wrap]').forEach(function (w) {
            if (!w.contains(t)) {
              w.classList.remove('is-open');
              var b = w.querySelector('[data-perfil-hero-plataforma-btn]');
              if (b) b.setAttribute('aria-expanded', 'false');
            }
          });
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeAllPerfilHeroPlataforma();
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPerfilHeroPlataforma);
    } else {
      initPerfilHeroPlataforma();
    }
    document.addEventListener('astro:page-load', initPerfilHeroPlataforma);
  })();
</script>

<style>
  .perfil-docentes-hero {
    width: 100%;
    background-color: #ffffff;
    padding: 0;
    position: relative;
    overflow-x: hidden;
    box-sizing: border-box;
  }

  .perfil-docentes-hero__strip {
    width: 85%;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
    background-color: #3868d0;
    position: relative;
    overflow-x: hidden;
    overflow-y: visible;
    padding-top: calc(1rem + 64px + 128px);
    padding-bottom: clamp(2.5rem, 6vw, 4rem);
    padding-left: 0;
    padding-right: 0;
    border-radius: 0 0 32px 32px;
    box-sizing: border-box;
  }

  .perfil-docentes-hero__inner {
    position: relative;
    z-index: 1;
  }

  .programas__label--align-start {
    justify-content: flex-start;
  }

  .perfil-docentes-hero__content .programas__label {
    margin-bottom: 24px;
    color: #ffffff;
  }

  .perfil-docentes-hero__row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    width: 100%;
    box-sizing: border-box;
  }

  .perfil-docentes-hero__content {
    text-align: left;
    margin: 0;
    min-width: 0;
    padding-left: 0;
    padding-right: 0;
    box-sizing: border-box;
  }

  .perfil-docentes-hero__title {
    margin: 0 0 clamp(1rem, 3vw, 1.5rem);
    max-width: 950px;
    color: #ffffff;
  }

  .perfil-docentes-hero__title-dot {
    color: var(--color-red);
  }

  .perfil-docentes-hero__subtitle {
    margin: 0 0 clamp(1.25rem, 4vw, 2.25rem);
    max-width: 950px;
    color: #ffffff;
  }

  .perfil-docentes-hero__ctas {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-start;
    gap: clamp(0.5rem, 2vw, 1rem);
    max-width: 100%;
    min-width: 0;
    overflow-x: visible;
    overflow-y: visible;
  }

  .perfil-docentes-hero__ctas .btn-base {
    flex: 0 0 auto;
    white-space: nowrap;
  }

  .perfil-docentes-hero__ctas .btn-base.btn-primary {
    background-image: linear-gradient(
      to right,
      var(--color-white) 50%,
      var(--color-blue-secondary) 50%
    );
    background-size: 200% 100%;
    color: var(--color-blue-primary);
    border: 2px solid transparent;
  }

  .perfil-docentes-hero__ctas .btn-base.btn-primary:hover {
    color: #ffffff;
  }

  .perfil-docentes-hero__ctas .btn-base.btn-secondary {
    background-image: linear-gradient(
      to right,
      transparent 50%,
      var(--color-blue-secondary) 50%
    );
    background-size: 200% 100%;
    background-color: transparent;
    color: #ffffff;
    border: 2px solid #ffffff;
  }

  .perfil-docentes-hero__ctas .btn-base.btn-secondary:hover {
    border-color: var(--color-blue-secondary);
  }

  .perfil-docentes-hero__plataforma-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
  }

  .perfil-docentes-hero__mega {
    position: absolute;
    bottom: calc(100% + 12px);
    top: auto;
    left: auto;
    right: 0;
    transform: none;
    min-width: 220px;
    padding: 1rem 0;
    background-color: #edf5ff;
    border-radius: 16px;
    box-shadow: 0 8px 32px rgba(40, 48, 148, 0.12);
    z-index: 20;
  }

  .perfil-docentes-hero__mega-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .perfil-docentes-hero__mega-list li {
    margin: 0;
    padding: 0;
  }

  .perfil-docentes-hero__mega-link {
    font-family: var(--font-family-base);
    font-weight: var(--text-body-primary-weight);
    font-size: var(--text-body-primary-size);
    letter-spacing: var(--text-body-primary-spacing);
    line-height: var(--text-body-primary-line);
    color: var(--color-blue);
    text-decoration: none;
    display: block;
    padding: 0.75rem 1.25rem;
    transition:
      color 0.2s ease,
      font-weight 0.2s ease,
      background-color 0.2s ease;
  }

  .perfil-docentes-hero__mega-link:hover,
  .perfil-docentes-hero__mega-link:focus {
    color: var(--color-blue-secondary);
    font-weight: var(--text-body-primary-highlight-weight);
    background-color: rgba(56, 67, 208, 0.06);
  }

  @media (min-width: 1101px) {
    .perfil-docentes-hero__mega {
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition: opacity 0.2s ease, visibility 0.2s ease;
    }

    .perfil-docentes-hero__plataforma-wrap:hover .perfil-docentes-hero__mega,
    .perfil-docentes-hero__plataforma-wrap:focus-within .perfil-docentes-hero__mega {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .perfil-docentes-hero__mega::before {
      content: '';
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      height: 16px;
    }
  }

  @media (max-width: 1100px) {
    .perfil-docentes-hero__mega {
      display: none;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transition: none;
    }

    .perfil-docentes-hero__mega::before {
      display: none;
    }

    .perfil-docentes-hero__plataforma-wrap.is-open .perfil-docentes-hero__mega {
      display: block;
    }
  }

  .perfil-docentes-hero__btn-icon {
    display: block;
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    background-color: currentColor;
    -webkit-mask-image: url('/icons/transversal/array-right-icon.svg');
    mask-image: url('/icons/transversal/array-right-icon.svg');
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
    transition: transform 0.2s ease;
  }

  .perfil-docentes-hero__ctas .btn-base:hover .perfil-docentes-hero__btn-icon {
    transform: translateX(3px);
  }

  .perfil-docentes-hero__plataforma-btn .perfil-docentes-hero__btn-icon--person {
    -webkit-mask-image: url('/icons/transversal/person-icon.svg');
    mask-image: url('/icons/transversal/person-icon.svg');
  }

  .perfil-docentes-hero__plataforma-btn:hover .perfil-docentes-hero__btn-icon--person {
    transform: none;
  }

  .perfil-docentes-hero__media {
    position: relative;
    z-index: 1;
    min-width: 0;
    width: 100%;
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
  }

  .perfil-docentes-hero__image {
    width: auto;
    max-width: min(500px, 100%);
    height: auto;
    max-height: clamp(260px, 52vw, 560px);
    display: block;
    object-fit: contain;
    object-position: right bottom;
    margin-left: auto;
    margin-right: 0;
  }

  @media (min-width: 1101px) {

    .perfil-docentes-hero__row {
      grid-template-columns: minmax(0, 1fr) 420px;
      gap: clamp(1.25rem, 3vw, 2.25rem);
      align-items: center;
    }

    .perfil-docentes-hero__content {
      min-width: 0;
      padding-right: 0;
    }

    .perfil-docentes-hero__title {
      margin-bottom: clamp(1rem, 2.5vw, 1.5rem);
    }

    .perfil-docentes-hero__subtitle {
      margin-bottom: clamp(1.25rem, 3.5vw, 2.25rem);
    }

    .perfil-docentes-hero__ctas {
      flex-wrap: nowrap;
      overflow-x: visible;
    }

    .perfil-docentes-hero__media {
      width: calc(100% + var(--layout-padding-x));
      max-width: calc(420px + var(--layout-padding-x));
      margin-right: calc(-1 * var(--layout-padding-x));
      justify-content: flex-end;
      align-items: flex-end;
    }

    .perfil-docentes-hero__image {
      width: 100%;
      max-width: 420px;
      max-height: clamp(320px, 42vw, 560px);
    }
  }

  @media (max-width: 1100px) {
    .perfil-docentes-hero__strip {
      width: 100%;
      max-width: none;
      margin-left: 0;
      margin-right: 0;
      border-radius: 0 0 28px 28px;
      padding-top: calc(0.5rem + 64px + 0.5rem + 80px);
    }

    .perfil-docentes-hero__inner.layout-container {
      max-width: none;
      padding-left: 0;
      padding-right: 0;
    }

    .perfil-docentes-hero__row {
      align-items: start;
    }

    .perfil-docentes-hero__content {
      padding-left: 24px;
      padding-right: 24px;
    }

    .perfil-docentes-hero__content .programas__label {
      margin-bottom: 0.5rem;
    }

    .perfil-docentes-hero__title,
    .perfil-docentes-hero__subtitle {
      max-width: none;
    }

    .perfil-docentes-hero__title {
      margin-bottom: clamp(1rem, 3vw, 1.25rem);
    }

    .perfil-docentes-hero__subtitle {
      margin-bottom: clamp(1rem, 3vw, 1.5rem);
    }

    .perfil-docentes-hero__ctas {
      flex-direction: column;
      align-items: stretch;
      flex-wrap: nowrap;
      width: 100%;
      max-width: none;
      margin-left: 0;
      margin-right: 0;
      overflow-x: visible;
      gap: 0.75rem;
      box-sizing: border-box;
    }

    .perfil-docentes-hero__ctas .btn-base {
      flex: 1 1 auto;
      width: 100%;
      max-width: none;
      white-space: normal;
      box-sizing: border-box;
    }

    .perfil-docentes-hero__media {
      width: 100%;
      max-width: none;
      margin-left: 0;
      margin-right: 0;
      justify-content: flex-end;
      align-items: flex-end;
    }

    .perfil-docentes-hero__image {
      width: 100%;
      max-width: none;
      height: auto;
      max-height: clamp(300px, 92vw, 460px);
      object-fit: contain;
      object-position: right bottom;
      margin-left: 0;
      margin-right: 0;
    }
  }
</style>
