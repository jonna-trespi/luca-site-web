---
/**
 * Directores: CTA previo al footer — tarjeta blanca con avatar y demo (sobrepuesto al footer).
 * Avatar: public/images/perfiles/docentes/footer-avatar.webp
 */
const avatarSrc = '/images/perfiles/docentes/footer-avatar.webp';
---

<section class="perfil-docentes-prefooter" aria-labelledby="perfil-docentes-prefooter-title">
  <div class="perfil-docentes-prefooter__inner layout-container">
    <div class="perfil-docentes-prefooter__card">
      <div class="perfil-docentes-prefooter__avatar-wrap" aria-hidden="true">
        <img
          class="perfil-docentes-prefooter__avatar"
          src={avatarSrc}
          alt=""
          width="180"
          height="200"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="perfil-docentes-prefooter__body">
        <h4 class="text-h4 perfil-docentes-prefooter__title" id="perfil-docentes-prefooter-title">
          Lidera la transformación educativa en tu colegio con Luca<span
            class="perfil-docentes-prefooter__title-dot"
            aria-hidden="true">.</span>
        </h4>
        <a
          href="#"
          class="btn-base btn-primary btn-cta-animated perfil-docentes-prefooter__cta"
          data-open-demo-modal
        >
          <span>Solicita demo gratis</span>
          <span class="perfil-docentes-prefooter__cta-icon" aria-hidden="true">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M11.235 16.089C11.105 16.178 10.958 16.221 10.811 16.221C10.572 16.221 10.338 16.108 10.192 15.896C9.958 15.555 10.044 15.088 10.385 14.853C11.969 13.763 13.445 12.415 13.542 11.969C13.445 11.583 11.969 10.236 10.385 9.148C10.045 8.913 9.958 8.446 10.192 8.105C10.426 7.763 10.892 7.677 11.235 7.911C12.656 8.887 15.04 10.716 15.04 11.999C15.04 13.282 12.656 15.112 11.235 16.089ZM12.25 2.25C5.051 2.25 2.5 4.802 2.5 12C2.5 19.198 5.051 21.75 12.25 21.75C19.448 21.75 22 19.198 22 12C22 4.802 19.448 2.25 12.25 2.25Z"
                fill="currentColor"></path>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .perfil-docentes-prefooter {
    position: relative;
    z-index: 2;
    width: 100%;
    background-color: #edf5ff;
    padding-top: 80px;
    padding-bottom: 0;
    box-sizing: border-box;
  }

  .perfil-docentes-prefooter__inner {
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .perfil-docentes-prefooter__card {
    position: relative;
    background: var(--color-white);
    border-radius: 32px;
    box-shadow: 0 20px 56px rgba(40, 48, 148, 0.12);
    padding: clamp(7rem, 18vw, 8.75rem) clamp(1.25rem, 3vw, 2rem) clamp(2.5rem, 5vw, 3.25rem);
    overflow: visible;
    box-sizing: border-box;
  }

  .perfil-docentes-prefooter__avatar-wrap {
    position: absolute;
    left: 50%;
    top: 0;
    transform: translate(-50%, -50%);
    width: 100%;
    max-width: 180px;
    pointer-events: none;
    z-index: 2;
  }

  .perfil-docentes-prefooter__avatar {
    display: block;
    width: 100%;
    max-width: 180px;
    height: auto;
    margin: 0 auto;
    object-fit: contain;
  }

  .perfil-docentes-prefooter__body {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.75rem;
  }

  .perfil-docentes-prefooter__title {
    margin: 0;
    max-width: 38rem;
    color: var(--color-text-base);
  }

  .perfil-docentes-prefooter__title-dot {
    color: var(--color-red);
  }

  .perfil-docentes-prefooter__cta {
    color: var(--color-white);
  }

  .perfil-docentes-prefooter__cta .perfil-docentes-prefooter__cta-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-white);
  }

  .perfil-docentes-prefooter__cta .perfil-docentes-prefooter__cta-icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  @media (min-width: 768px) {
    .perfil-docentes-prefooter__card {
      padding-left: clamp(2rem, 4vw, 2.75rem);
      padding-right: clamp(2rem, 4vw, 2.75rem);
    }
  }
</style>
