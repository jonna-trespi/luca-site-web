---
/**
 * Hero Estudiantes: franja 80%, fondo #3843D0, dos columnas (copy + imagen), CTAs primario/secundario.
 * Imagen: public/images/perfiles/estudiantes/image-hero.webp
 */
const heroImageSrc = '/images/perfiles/estudiantes/image-hero.webp';
---

<section class="perfil-estudiantes-hero">
  <div class="perfil-estudiantes-hero__strip">
    <div class="perfil-estudiantes-hero__inner layout-container">
      <div class="perfil-estudiantes-hero__row">
        <header class="perfil-estudiantes-hero__content">
          <p class="programas__label programas__label--align-start">
            <span class="programas__label-dot" aria-hidden="true"></span>
            Estudiantes
          </p>
          <h1 id="perfil-estudiantes-hero-title" class="perfil-estudiantes-hero__title text-h1">
            Luca convierte el aprendizaje en un juego con propósito<span class="perfil-estudiantes-hero__title-dot" aria-hidden="true">.</span>
          </h1>
          <p class="perfil-estudiantes-hero__subtitle text-subtitle-1">
            Aprendizaje gamificado
          </p>
          <div class="perfil-estudiantes-hero__ctas">
            <a href="#" class="btn-base btn-primary btn-cta-animated" data-open-demo-modal>
              <span>Solicita tu demo</span>
              <span class="perfil-estudiantes-hero__btn-icon" aria-hidden="true"></span>
            </a>
            <a href="#" class="btn-base btn-secondary btn-cta-animated">
              <span>Ingresa a la plataforma</span>
              <span class="perfil-estudiantes-hero__btn-icon" aria-hidden="true"></span>
            </a>
          </div>
        </header>
        <div class="perfil-estudiantes-hero__media">
          <img
            class="perfil-estudiantes-hero__image"
            src={heroImageSrc}
            alt="Estudiante usando Luca"
            width="500"
            height="560"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .perfil-estudiantes-hero {
    width: 100%;
    background-color: #ffffff;
    padding: 0;
    position: relative;
    overflow-x: hidden;
    box-sizing: border-box;
  }

  .perfil-estudiantes-hero__strip {
    width: 85%;
    max-width: 100%;
    margin-left: auto;
    margin-right: auto;
    background-color: #3843d0;
    position: relative;
    overflow: hidden;
    padding-top: calc(1rem + 64px + 128px);
    padding-bottom: clamp(2.5rem, 6vw, 4rem);
    padding-left: 0;
    padding-right: 0;
    border-radius: 0 0 32px 32px;
    box-sizing: border-box;
  }

  .perfil-estudiantes-hero__inner {
    position: relative;
    z-index: 1;
  }

  .programas__label--align-start {
    justify-content: flex-start;
  }

  .perfil-estudiantes-hero__content .programas__label {
    margin-bottom: 24px;
    color: #ffffff;
  }

  .perfil-estudiantes-hero__row {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    width: 100%;
    box-sizing: border-box;
  }

  .perfil-estudiantes-hero__content {
    text-align: left;
    margin: 0;
    min-width: 0;
    padding-left: 0;
    padding-right: 0;
    box-sizing: border-box;
  }

  .perfil-estudiantes-hero__title {
    margin: 0 0 clamp(1rem, 3vw, 1.5rem);
    max-width: 950px;
    color: #ffffff;
  }

  .perfil-estudiantes-hero__title-dot {
    color: var(--color-red);
  }

  .perfil-estudiantes-hero__subtitle {
    margin: 0 0 clamp(1.25rem, 4vw, 2.25rem);
    max-width: 950px;
    color: #ffffff;
  }

  .perfil-estudiantes-hero__ctas {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: flex-start;
    gap: clamp(0.5rem, 2vw, 1rem);
    max-width: 100%;
    min-width: 0;
    overflow-x: visible;
    overflow-y: visible;
  }

  .perfil-estudiantes-hero__ctas .btn-base {
    flex: 0 0 auto;
    white-space: nowrap;
  }

  .perfil-estudiantes-hero__ctas .btn-base.btn-primary {
    background-image: linear-gradient(
      to right,
      var(--color-white) 50%,
      var(--color-blue-secondary) 50%
    );
    background-size: 200% 100%;
    color: var(--color-blue-primary);
    border: 2px solid transparent;
  }

  .perfil-estudiantes-hero__ctas .btn-base.btn-primary:hover {
    color: #ffffff;
  }

  .perfil-estudiantes-hero__ctas .btn-base.btn-secondary {
    background-image: linear-gradient(
      to right,
      transparent 50%,
      var(--color-blue-secondary) 50%
    );
    background-size: 200% 100%;
    background-color: transparent;
    color: #ffffff;
    border: 2px solid #ffffff;
  }

  .perfil-estudiantes-hero__ctas .btn-base.btn-secondary:hover {
    border-color: var(--color-blue-secondary);
  }

  .perfil-estudiantes-hero__btn-icon {
    display: block;
    width: 1.25rem;
    height: 1.25rem;
    flex-shrink: 0;
    background-color: currentColor;
    -webkit-mask-image: url('/icons/transversal/array-right-icon.svg');
    mask-image: url('/icons/transversal/array-right-icon.svg');
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    -webkit-mask-size: contain;
    mask-size: contain;
    transition: transform 0.2s ease;
  }

  .perfil-estudiantes-hero__ctas .btn-base:hover .perfil-estudiantes-hero__btn-icon {
    transform: translateX(3px);
  }

  .perfil-estudiantes-hero__media {
    position: relative;
    z-index: 1;
    min-width: 0;
    width: 100%;
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
  }

  .perfil-estudiantes-hero__image {
    width: auto;
    max-width: min(500px, 100%);
    height: auto;
    max-height: clamp(260px, 52vw, 560px);
    display: block;
    object-fit: contain;
    object-position: right bottom;
    margin-left: auto;
    margin-right: 0;
  }

  @media (min-width: 1101px) {

    .perfil-estudiantes-hero__row {
      grid-template-columns: minmax(0, 1fr) 420px;
      gap: clamp(1.25rem, 3vw, 2.25rem);
      align-items: center;
    }

    .perfil-estudiantes-hero__content {
      min-width: 0;
      padding-right: 0;
    }

    .perfil-estudiantes-hero__title {
      margin-bottom: clamp(1rem, 2.5vw, 1.5rem);
    }

    .perfil-estudiantes-hero__subtitle {
      margin-bottom: clamp(1.25rem, 3.5vw, 2.25rem);
    }

    .perfil-estudiantes-hero__ctas {
      flex-wrap: nowrap;
      overflow-x: visible;
    }

    .perfil-estudiantes-hero__media {
      width: calc(100% + var(--layout-padding-x));
      max-width: calc(420px + var(--layout-padding-x));
      margin-right: calc(-1 * var(--layout-padding-x));
      justify-content: flex-end;
      align-items: flex-end;
    }

    .perfil-estudiantes-hero__image {
      width: 100%;
      max-width: 420px;
      max-height: clamp(320px, 42vw, 560px);
    }
  }



  @media (max-width: 1100px) {
    .perfil-estudiantes-hero__strip {
      width: 100%;
      max-width: none;
      margin-left: 0;
      margin-right: 0;
      border-radius: 0 0 28px 28px;
      padding-top: calc(0.5rem + 64px + 0.5rem + 80px);
    }

    .perfil-estudiantes-hero__inner.layout-container {
      max-width: none;
      padding-left: 0;
      padding-right: 0;
    }

    .perfil-estudiantes-hero__row {
      align-items: start;
    }

    .perfil-estudiantes-hero__content {
      padding-left: 24px;
      padding-right: 24px;
    }

    .perfil-estudiantes-hero__content .programas__label {
      margin-bottom: 0.5rem;
    }

    .perfil-estudiantes-hero__title,
    .perfil-estudiantes-hero__subtitle {
      max-width: none;
    }

    .perfil-estudiantes-hero__title {
      margin-bottom: clamp(1rem, 3vw, 1.25rem);
    }

    .perfil-estudiantes-hero__subtitle {
      margin-bottom: clamp(1rem, 3vw, 1.5rem);
    }

    .perfil-estudiantes-hero__ctas {
      flex-direction: column;
      align-items: stretch;
      flex-wrap: nowrap;
      width: 100%;
      max-width: none;
      margin-left: 0;
      margin-right: 0;
      overflow-x: visible;
      gap: 0.75rem;
      box-sizing: border-box;
    }

    .perfil-estudiantes-hero__ctas .btn-base {
      flex: 1 1 auto;
      width: 100%;
      max-width: none;
      white-space: normal;
      box-sizing: border-box;
    }

    .perfil-estudiantes-hero__media {
      width: 100%;
      max-width: none;
      margin-left: 0;
      margin-right: 0;
      justify-content: flex-end;
      align-items: flex-end;
    }

    .perfil-estudiantes-hero__image {
      width: 100%;
      max-width: none;
      height: auto;
      max-height: clamp(300px, 92vw, 460px);
      object-fit: contain;
      object-position: right bottom;
      margin-left: 0;
      margin-right: 0;
    }
  }
</style>
