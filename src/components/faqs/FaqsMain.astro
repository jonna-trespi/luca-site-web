---

<section class="faqs-main" aria-label="Buscador y preguntas frecuentes" data-faqs-page>
  <img
    class="faqs-main__deco"
    src="/images/faqs/geo-3.png"
    alt=""
    width="480"
    height="480"
    loading="lazy"
    decoding="async"
    aria-hidden="true"
  />

  <div class="faqs-main__inner layout-container">
    <div class="faqs-main__search">
      <label class="visually-hidden" for="faqs-search-input">Buscar en preguntas frecuentes</label>
      <div class="faqs-main__search-field">
        <input
          type="search"
          id="faqs-search-input"
          class="faqs-main__search-input"
          placeholder="Buscar"
          autocomplete="off"
          data-faqs-search
        />
        <span class="faqs-main__search-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16zm9 2-4.35-4.35"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            ></path>
          </svg>
        </span>
      </div>
    </div>

    <div class="faqs-main__layout">
      <nav class="faqs-main__tabs" aria-label="Categorías de preguntas">
        <div class="faqs-main__tabs-rail">
          <ul class="faqs-main__tabs-list" role="tablist">
            {tabs.map((tab, i) => (
              <li class="faqs-main__tabs-item" role="none">
                <button
                  type="button"
                  class:list={['faqs-main__tab', i === 0 && 'faqs-main__tab--active']}
                  role="tab"
                  id={`faqs-tab-${tab.id}`}
                  aria-selected={i === 0}
                  aria-controls={`faqs-panel-${tab.id}`}
                  tabindex={i === 0 ? 0 : -1}
                  data-faqs-tab={tab.id}
                >
                  {tab.label}
                </button>
              </li>
            ))}
          </ul>
        </div>
      </nav>

      <div class="faqs-main__panels">
        {tabs.map((tab, i) => (
          <div
            class="faqs-main__panel"
            id={`faqs-panel-${tab.id}`}
            role="tabpanel"
            aria-labelledby={`faqs-tab-${tab.id}`}
            hidden={i !== 0}
            data-faqs-panel={tab.id}
          >
            {tab.items.length === 0 ? (
              <p class="faqs-main__empty text-body-primary">
                Contenido de esta sección en preparación. Vuelve pronto o revisa la pestaña Generales.
              </p>
            ) : (
              <ul class="faqs-main__accordion">
                {tab.items.map((item, j) => (
                  <li class="faqs-main__item" data-faqs-item>
                    <div class="faqs-main__card">
                      <button
                        type="button"
                        class="faqs-main__trigger"
                        aria-expanded="false"
                        aria-controls={`faqs-answer-${tab.id}-${j}`}
                        id={`faqs-trigger-${tab.id}-${j}`}
                        data-faqs-trigger
                      >
                        <span class="faqs-main__question text-subtitle-2">{item.question}</span>
                        <span class="faqs-main__icon" aria-hidden="true"></span>
                      </button>
                      <div
                        class="faqs-main__answer-wrap"
                        id={`faqs-answer-${tab.id}-${j}`}
                        role="region"
                        aria-labelledby={`faqs-trigger-${tab.id}-${j}`}
                      >
                        <div class="faqs-main__answer">
                          {item.answerHtml ? (
                            <div class="faqs-main__answer-body text-body-primary" set:html={item.answerHtml} />
                          ) : (
                            <p class="text-body-primary">{item.answer}</p>
                          )}
                        </div>
                      </div>
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    function initFaqsPage() {
      var root = document.querySelector('[data-faqs-page]');
      if (!root) return;
      if (root.getAttribute('data-faqs-bound') === '1') return;
      root.setAttribute('data-faqs-bound', '1');

      var tabs = root.querySelectorAll('[data-faqs-tab]');
      var panels = root.querySelectorAll('[data-faqs-panel]');
      var searchInput = root.querySelector('[data-faqs-search]');

      function setTab(tabId) {
        tabs.forEach(function (btn) {
          var on = btn.getAttribute('data-faqs-tab') === tabId;
          btn.setAttribute('aria-selected', on ? 'true' : 'false');
          btn.tabIndex = on ? 0 : -1;
          btn.classList.toggle('faqs-main__tab--active', on);
        });
        panels.forEach(function (panel) {
          var match = panel.getAttribute('data-faqs-panel') === tabId;
          panel.hidden = !match;
        });
        filterItems();
      }

      function filterItems() {
        var q = (searchInput && searchInput.value ? searchInput.value : '').trim().toLowerCase();
        var visiblePanel = Array.prototype.find.call(panels, function (p) {
          return !p.hidden;
        });
        if (!visiblePanel) return;
        visiblePanel.querySelectorAll('[data-faqs-item]').forEach(function (li) {
          var text = (li.textContent || '').toLowerCase();
          var show = !q || text.indexOf(q) !== -1;
          li.style.display = show ? '' : 'none';
        });
      }

      tabs.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var id = btn.getAttribute('data-faqs-tab');
          if (id) setTab(id);
        });
      });

      if (searchInput) {
        searchInput.addEventListener('input', filterItems);
        searchInput.addEventListener('search', filterItems);
      }

      root.querySelectorAll('[data-faqs-trigger]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var card = btn.closest('.faqs-main__card');
          var expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!expanded));
          if (card) card.classList.toggle('faqs-main__card--expanded', !expanded);
        });
      });

    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFaqsPage);
    } else {
      initFaqsPage();
    }
    document.addEventListener('astro:page-load', initFaqsPage);
  })();
</script>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .faqs-main {
    position: relative;
    width: 100%;
    background-color: #ffffff;
    padding: 1.5rem 0 clamp(2.5rem, 6vw, 4.5rem);
    overflow: hidden;
    box-sizing: border-box;
  }

  /* Hoja decorativa: esquina inferior izquierda del bloque (viewport en ancho completo de la sección) */
  .faqs-main__deco {
    position: absolute;
    left: 0;
    bottom: 0;
    max-width: min(440px, 78vw);
    width: auto;
    height: auto;
    transform: translate(-12%, 8%);
    opacity: 1;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    object-fit: contain;
    object-position: left bottom;
  }

  .faqs-main__inner.layout-container {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--layout-padding-x);
    padding-right: var(--layout-padding-x);
  }

  .faqs-main__search {
    margin-bottom: 1.75rem;
  }

  .faqs-main__search-field {
    position: relative;
    max-width: 420px;
    width: 100%;
  }

  .faqs-main__search-input {
    width: 100%;
    box-sizing: border-box;
    padding: 0.9rem 3rem 0.9rem 1.15rem;
    border: none;
    border-radius: 999px;
    background: #e8ecf2;
    font-family: var(--font-family-base);
    font-size: var(--text-body-primary-size);
    color: var(--color-text-base);
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.04);
  }

  .faqs-main__search-input::placeholder {
    color: #8891a8;
  }

  .faqs-main__search-input:focus {
    outline: 2px solid var(--color-blue-primary);
    outline-offset: 2px;
  }

  .faqs-main__search-icon {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-blue-primary);
    display: flex;
    pointer-events: none;
  }

  .faqs-main__layout {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: stretch;
  }

  @media (min-width: 900px) {
    .faqs-main__layout {
      flex-direction: row;
      align-items: flex-start;
      gap: clamp(1.5rem, 3vw, 2.75rem);
    }
  }

  .faqs-main__tabs {
    flex-shrink: 0;
  }

  /* Carril gris continuo (solo desktop); en móvil no aplica */
  .faqs-main__tabs-rail {
    position: relative;
  }

  @media (min-width: 900px) {
    .faqs-main__tabs-rail {
      padding-left: 1.25rem;
    }

    .faqs-main__tabs-rail::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 1px;
      background-color: #e2e6ee;
    }
  }

  .faqs-main__tabs-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 0.5rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    padding-bottom: 0.35rem;
  }

  @media (min-width: 900px) {
    .faqs-main__tabs-list {
      flex-direction: column;
      flex-wrap: nowrap;
      overflow: visible;
      gap: 70px;
      min-width: 140px;
      padding-bottom: 0;
    }
  }

  .faqs-main__tabs-item {
    flex-shrink: 0;
  }

  @media (min-width: 900px) {
    .faqs-main__tabs-item {
      flex-shrink: 0;
      width: 100%;
    }
  }

  .faqs-main__tab {
    display: block;
    width: 100%;
    text-align: left;
    padding: 0;
    border: none;
    background: transparent;
    font-family: var(--font-family-base);
    font-size: var(--text-body-secondary-size);
    font-weight: 400;
    color: #3d3d3d;
    cursor: pointer;
    border-radius: 0;
