---
/**
 * Videolecciones: título, subtítulo 1, vídeo embebido (autoplay, sin controles) y figuras geo-7 / geo-8.
 */
const VIDEO_ID = 'O5pA-K5gvhc';
const embedSrc = `https://www.youtube.com/embed/${VIDEO_ID}?autoplay=1&mute=1&loop=1&playlist=${VIDEO_ID}&controls=0&modestbranding=1&rel=0`;
---
<section class="videolecciones-primaria">
  <div class="videolecciones-primaria__geo7" aria-hidden="true">
    <img src="/images/programas/primaria/geo-7.webp" alt="" width="250" height="214" loading="lazy" decoding="async" />
  </div>

  <div class="videolecciones-primaria__inner layout-container">
    <h3 class="text-h3 videolecciones-primaria__title">
      Videolecciones<span class="videolecciones-primaria__title-dot">.</span>
    </h3>
    <p class="videolecciones-primaria__subtitle text-subtitle-1">
      Creadas por expertos de las plataformas y televisoras más reconocidas como Netflix, Prime Video, Sony, CBS, entre
      otras.
    </p>

    <div class="videolecciones-primaria__media">
      <div class="videolecciones-primaria__geo8" aria-hidden="true">
        <img src="/images/programas/primaria/geo-8.webp" alt="" width="230" height="230" loading="lazy" decoding="async" />
      </div>
      <div class="videolecciones-primaria__video-shell">
        <iframe
          class="videolecciones-primaria__iframe"
          src={embedSrc}
          title="Videolecciones Luca"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </div>
</section>

<style>
  .videolecciones-primaria {
    position: relative;
    width: 100%;
    background-color: var(--color-bg-base);
    padding: 3rem 0;
    overflow: hidden;
    z-index: 0;
  }

  .videolecciones-primaria__inner {
    position: relative;
    z-index: 1;
  }

  /* Fondo: forma amarilla pegada al borde derecho del viewport */
  .videolecciones-primaria__geo7 {
    position: absolute;
    right: 0;
    top: 0;
    width: min(100%, 250px);
    max-width: 250px;
    z-index: 0;
    pointer-events: none;
    transform: translateY(-8%);
  }

  .videolecciones-primaria__geo7 img {
    display: block;
    width: 100%;
    height: auto;
    margin-left: auto;
    object-fit: contain;
    object-position: right top;
  }

  .videolecciones-primaria__title {
    max-width: 650px;
    margin: 0 auto;
    text-align: center;
    color: var(--color-text-base);
  }

  .videolecciones-primaria__title-dot {
    color: var(--color-red);
  }

  .videolecciones-primaria__subtitle {
    max-width: 650px;
    margin: 24px auto 54px;
    text-align: center;
    color: var(--color-text-base);
  }

  .videolecciones-primaria__media {
    position: relative;
    width: 100%;
    max-width: min(960px, 100%);
    margin: 0 auto;
  }

  /* Detrás del vídeo, esquina inferior izquierda */
  .videolecciones-primaria__geo8 {
    position: absolute;
    left: -10%;
    bottom: -10%;
    z-index: 0;
    max-width: 230px;
    width: min(32%, 230px);
    pointer-events: none;
  }

  .videolecciones-primaria__geo8 img {
    width: 100%;
    max-width: 230px;
    height: auto;
    display: block;
  }

  .videolecciones-primaria__video-shell {
    position: relative;
    z-index: 1;
    border-radius: 24px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: var(--color-black);
    box-shadow: 0 16px 48px rgba(56, 67, 208, 0.12), 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .videolecciones-primaria__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  @media (min-width: 1101px) {
    .videolecciones-primaria {
      padding: 4rem 0;
    }
  }

  @media (min-width: 1101px) {
    .videolecciones-primaria {
      padding: 5rem 0;
    }
  }

  @media (max-width: 1100px) {
    .videolecciones-primaria__geo7 {
      top: 30%;
      transform: none;
      opacity: 0.95;
    }

    .videolecciones-primaria__geo8 {
      width: min(40%, 230px);
    }
  }
</style>
