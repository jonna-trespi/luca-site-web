</style>

<script>
  (function () {
    const cardsEl = document.getElementById('programas-cards');
    if (!cardsEl) return;

    const getCards = () => Array.from(cardsEl.querySelectorAll('.programas__card[data-card]'));
    const setActive = (key: string) => {
      if (!['kinder', 'primaria', 'secundaria'].includes(key)) return;
      cardsEl.setAttribute('data-active', key);
      getCards().forEach((card) => {
        const id = card.getAttribute('data-card');
        card.setAttribute('aria-expanded', id === key ? 'true' : 'false');
      });
    };

    const isMobile = () => window.matchMedia('(max-width: 1100px)').matches;

    const programNav: Record<string, string> = {
      kinder: '/programas/preescolar',
      primaria: '/programas/primaria',
      secundaria: '/programas/secundaria',
    };

    const activateCard = (e: Event) => {
      const target = (e.target as HTMLElement).closest('.programas__card[data-card]');
      if (!target) return;
      const key = (target as HTMLElement).getAttribute('data-card');
      if (e.type === 'click' && key && programNav[key]) {
        window.location.href = programNav[key];
        return;
      }
      if (isMobile()) return;
      if (e.target && (e.target as HTMLElement).closest('a[href]')) return;
      if (!key) return;
      setActive(key);
    };

    const handleKeydown = (e: KeyboardEvent) => {
      const target = (e.target as HTMLElement).closest('.programas__card[data-card]');
      if (!target) return;
      const key = (target as HTMLElement).getAttribute('data-card');
      if (key && programNav[key]) {
        if (e.key !== 'Enter' && e.key !== ' ') return;
        e.preventDefault();
        window.location.href = programNav[key];
        return;
      }
      if (isMobile()) return;
      if (e.key !== 'Enter' && e.key !== ' ') return;
      e.preventDefault();
      if (key) setActive(key);
    };

    cardsEl.addEventListener('click', activateCard);
    cardsEl.addEventListener('mouseenter', activateCard, true);
    cardsEl.addEventListener('keydown', handleKeydown);
  })();

  (function stackedCards() {
    const wrapper = document.getElementById('stacked-cards');
    if (!wrapper) return;

    const cards = Array.from(wrapper.querySelectorAll('.card-item[data-card]'));
    const stickyTopPx = () => window.innerHeight * 0.1;
    const overlapRange = () =>
      window.innerWidth <= 1100 ? Math.min(250, Math.max(160, window.innerHeight * 0.32)) : 250;

    function updateStack() {
      const top = stickyTopPx();
      const range = overlapRange();
      cards.forEach((card, i) => {
        const next = cards[i + 1];
        const el = card as HTMLElement;
        if (!next) {
          el.style.setProperty('--stack', '0');
          return;
        }
        const nextRect = next.getBoundingClientRect();
        const progress = 1 - (nextRect.top - top) / range;
        const value = Math.max(0, Math.min(1, progress));
        el.style.setProperty('--stack', String(value));
      });
    }

    let ticking = false;
    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateStack();
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    updateStack();
  })();
</script>
