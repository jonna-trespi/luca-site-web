  /* Tablet y móvil: 3 cards en columna (sin carrusel horizontal que se corta ~800px) */
  @media (max-width: 1100px) {
    /* overflow solo en la fila de programas: si está en .programas rompe sticky del bloque EdTech */
    .programas__cards {
